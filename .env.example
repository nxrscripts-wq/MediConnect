# Supabase — obter em app.supabase.com > Project Settings > API
# URL do projeto Supabase (ex: https://abc.supabase.co)
VITE_SUPABASE_URL=https://SEU_PROJECTO.supabase.co

# Anon key pública do Supabase
VITE_SUPABASE_ANON_KEY=eyJ...

# Ambiente (development | staging | production)
VITE_APP_ENV=development

# Versão (preenchida automaticamente pelo npm)
VITE_APP_VERSION=0.1.0
